---
import { Icon } from "astro-icon/components";
import VerticalNavbar from "./VerticalNavbar.astro";

interface CardProps {
  title: string;
  subtitle?: string;
}
interface Props {
  heading: string;
  subtitles?: { label: string; url: string }[];
  cards: {
    left: CardProps;
    topLeft: CardProps;
    topRight: CardProps;
    bottomLeft: CardProps;
    bottomRight: CardProps;
  };
  activeNavIndex?: number;
}
const { heading, subtitles = [], cards, activeNavIndex = 0 } = Astro.props;

const navItems = [
  { label: "Inicio", href: "#inicio" },
  { label: "Biografía", href: "#biografia" },
  { label: "Más Proyectos", href: "#proyectos" },
];

const subtitleIcons: Record<string, string> = {
  github: "lucide:github",
  linkedin: "lucide:linkedin",
  telefono: "lucide:phone",
  teléfono: "lucide:phone",
  phone: "lucide:phone",
};

function getIcon(label: string): string {
  return subtitleIcons[label.toLowerCase()] ?? "lucide:link";
}
---

<section
  class="h-screen overflow-hidden p-8 bg-[#f5f5f0] font-mono flex flex-col gap-4"
>
  <div class="flex flex-1 min-h-0 gap-4">
    <!-- Vertical Navbar -->
    <aside
      class="flex-none w-16 flex items-center justify-center"
      aria-label="Barra de navegación lateral"
    >
      <VerticalNavbar items={navItems} activeIndex={activeNavIndex} />
    </aside>

    <!-- Bento grid -->
    <div
      class="flex-1 min-h-0 grid gap-4"
      style="grid-template-columns: 38% 1fr; grid-template-rows: 1fr;"
    >
      <!-- Left card (tall) -->
      <article
        class="h-full rounded-2xl p-6 flex flex-col gap-2 transition-transform duration-300 hover:-translate-y-1 hover:shadow-2xl cursor-default overflow-hidden"
        style="background-color: var(--color-navy); color: #fff;"
      >
        <span class="text-4xl font-bold tracking-tight leading-tight"
          >{cards.left.title}</span
        >
        {
          cards.left.subtitle && (
            <span class="text-md opacity-70 tracking-wide">
              {cards.left.subtitle}
            </span>
          )
        }
      </article>

      <!-- Right side -->
      <div class="flex flex-col gap-4 min-h-0">
        <header class="flex-none flex flex-col gap-1">
          <h1
            class="text-[clamp(3rem,7vw,7rem)] font-black uppercase tracking-tighter leading-none text-black text-center"
          >
            {heading}
          </h1>

          <div class="flex justify-between">
            {
              subtitles.map((s) => (
                <a
                  href={s.url}
                  target="_blank"
                  class="flex items-center gap-1.5 text-lg text-neutral-500 tracking-wide hover:text-black transition-colors duration-200"
                >
                  <Icon name={getIcon(s.label)} size={18} />
                  {s.label}
                </a>
              ))
            }
          </div>
        </header>

        <!-- 2×2 cards -->
        <div
          class="flex-1 grid grid-cols-2 gap-4 min-h-0"
          style="grid-template-rows: 1.6fr 1fr;"
        >
          <article
            class="rounded-2xl p-6 flex flex-col gap-2 transition-transform duration-300 hover:-translate-y-1 hover:shadow-2xl cursor-default overflow-hidden"
            style="background-color: var(--color-sky); color: black;"
          >
            <span class="text-4xl font-bold tracking-tight leading-tight"
              >{cards.topLeft.title}</span
            >
            {
              cards.topLeft.subtitle && (
                <span class="text-xs opacity-70 tracking-wide">
                  {cards.topLeft.subtitle}
                </span>
              )
            }
          </article>
          <article
            class="rounded-2xl p-6 flex flex-col gap-2 transition-transform duration-300 hover:-translate-y-1 hover:shadow-2xl cursor-default overflow-hidden"
            style="background-color: var(--color-yellow); color: black;"
          >
            <span class="text-4xl font-bold tracking-tight leading-tight"
              >{cards.topRight.title}</span
            >
            {
              cards.topRight.subtitle && (
                <span class="text-xs opacity-70 tracking-wide">
                  {cards.topRight.subtitle}
                </span>
              )
            }
          </article>
          <article
            class="rounded-2xl p-6 flex flex-col gap-2 transition-transform duration-300 hover:-translate-y-1 hover:shadow-2xl cursor-default overflow-hidden"
            style="background-color: var(--color-blue); color: #fff;"
          >
            <span class="text-4xl font-bold tracking-tight leading-tight"
              >{cards.bottomLeft.title}</span
            >
            {
              cards.bottomLeft.subtitle && (
                <span class="text-xs opacity-70 tracking-wide">
                  {cards.bottomLeft.subtitle}
                </span>
              )
            }
          </article>
          <article
            class="rounded-2xl p-6 flex flex-col gap-2 transition-transform duration-300 hover:-translate-y-1 hover:shadow-2xl cursor-default overflow-hidden"
            style="background-color: var(--color-orange); color: #fff;"
          >
            <span class="text-4xl font-bold tracking-tight leading-tight"
              >{cards.bottomRight.title}</span
            >
            {
              cards.bottomRight.subtitle && (
                <span class="text-xs opacity-70 tracking-wide">
                  {cards.bottomRight.subtitle}
                </span>
              )
            }
          </article>
        </div>
      </div>
    </div>
  </div>

  <style>
    @media (max-width: 768px) {
      aside {
        display: none;
      }
      .grid[style*="grid-template-columns"] {
        grid-template-columns: 1fr !important;
      }
    }
  </style>
</section>
