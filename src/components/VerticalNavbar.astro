---
interface Props {
  items: { label: string; href: string }[];
  activeIndex?: number;
}

const { items, activeIndex = 0 } = Astro.props;
---

<nav class="vertical-nav" aria-label="Navegación vertical">
  <ul class="nav-list">
    {items.map((item, i) => (
      <li class={`nav-item ${i === activeIndex ? 'active' : ''}`}>
        <a href={item.href} class="nav-link" data-index={i}>
          {i === activeIndex && <span class="active-dot" aria-hidden="true" />}
          <span class="nav-label">{item.label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .vertical-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100%;
    width: 100%;
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;   /* items apilados verticalmente */
    align-items: flex-start;
    gap: 2rem;
  }

  .nav-item {
    display: flex;
    align-items: center;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    font-family: 'Courier New', monospace;
    font-size: 1rem;           /* más grande */
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #9ca3af;
    padding: 4px 0;
    transition: color 0.2s ease;
    /* Rotamos el texto 90° antihorario para que se lea de abajo hacia arriba */
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    white-space: nowrap;
  }

  .nav-link:hover {
    color: #111;
  }

  .nav-item.active .nav-link {
    color: #111;
    font-weight: 700;
  }

  .active-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background-color: #111;
    flex-shrink: 0;
  }

  .nav-label {
    white-space: nowrap;
  }
</style>

<script>
  const links = document.querySelectorAll('.nav-link');
  links.forEach((link) => {
    link.addEventListener('click', () => {
      document.querySelectorAll('.nav-item').forEach((li) => li.classList.remove('active'));
      document.querySelectorAll('.active-dot').forEach((dot) => dot.remove());
      const parentLi = link.closest('.nav-item');
      if (parentLi) {
        parentLi.classList.add('active');
        const dot = document.createElement('span');
        dot.className = 'active-dot';
        dot.setAttribute('aria-hidden', 'true');
        link.prepend(dot);
      }
    });
  });
</script>